# ============================================================
# Plantilla de variables de entorno.
# Copiar a .env y ajustar los valores:  cp .env.example .env
# ============================================================

# ── Credenciales de PostgreSQL (compartidas por las 3 BDs) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar-esta-clave

# ── Puertos internos de los microservicios ──
# Los usan tanto los servicios como el nginx del API Gateway.
PEDIDOS_PORT=3001
INVENTARIO_PORT=3002
CONTABILIDAD_PORT=3003

# ── Puertos expuestos en el host ──
GATEWAY_PORT=80
FRONTEND_PORT=3000
KAFKA_PORT=9092
KAFKA_UI_PORT=8080
POSTGRES_PEDIDOS_PORT=5433
POSTGRES_INVENTARIO_PORT=5434
POSTGRES_CONTABILIDAD_PORT=5435
PGADMIN_PORT=5050

# ── pgAdmin (visor web de las bases de datos) ──
PGADMIN_DEFAULT_EMAIL=admin@insumos.com
PGADMIN_DEFAULT_PASSWORD=cambiar-esta-clave
